window.BABLoader = {
    tips: [
        "初回プレイは約 90MB のデータ取得があります。コーヒーをどうぞ。",
        "連鎖を繋げると得点倍率がグンと上がります。",
        "レーザーはチャージ後、R キーで発射。",
        "シールドを削られても、被弾しなければ連鎖ボーナスは維持されます。",
        "ボス撃破後のスコア集計をお見逃しなく。",
        "NIGHTMARE は HARD クリア後に解放されます。",
        "Q キー / Start でポーズ。設定はタイトルから変更できます。"
    ],
    tipIndex: 0,
    tipTimer: null,
    lastPct: 0,

    init() {
        this.overlay = document.getElementById("bab-loader");
        this.barFill = document.getElementById("bab-bar-fill");
        this.percent = document.getElementById("bab-percent");
        this.stage = document.getElementById("bab-stage");
        this.tip = document.getElementById("bab-tip");
        this.progress = document.getElementById("progress");
        this.status = document.getElementById("status");

        const sync = () => this.syncProgress();
        if (this.progress) {
            new MutationObserver(sync).observe(this.progress, {
                attributes: true,
                attributeFilter: ["value", "max", "hidden"]
            });
        }
        if (this.status) {
            new MutationObserver(sync).observe(this.status, {
                childList: true,
                characterData: true,
                subtree: true
            });
        }
        this.syncTimer = setInterval(sync, 80);
        this.tipTimer = setInterval(() => this.rotateTip(), 4200);
        this.rotateTip();
        sync();
    },

    stageFromStatus(text) {
        const t = (text || "").toLowerCase();
        if (t.includes("download")) return "データをダウンロードしています…";
        if (t.includes("wasm") || t.includes("compile")) return "WebAssembly をコンパイルしています…";
        if (t.includes("preload") || t.includes("load")) return "ランタイムを準備しています…";
        if (t.includes("run")) return "起動準備中…";
        return "読み込み中…";
    },

    syncProgress() {
        const p = this.progress;
        let pct = this.lastPct;
        if (p && !p.hidden && p.max > 0) {
            const raw = (parseFloat(p.value) || 0) / (parseFloat(p.max) || 100);
            pct = Math.min(99, Math.max(0, raw * 100));
            if (parseFloat(p.value) > 100) {
                pct = Math.min(99, 70 + (parseFloat(p.value) - 100) * 0.6);
            }
        }
        if (pct > this.lastPct) {
            this.lastPct = pct;
        }
        this.setPercent(this.lastPct);
        if (this.status && this.status.textContent) {
            const label = this.stageFromStatus(this.status.textContent);
            if (this.stage && pct < 80) {
                this.stage.textContent = label;
            }
        }
    },

    setPercent(pct) {
        const v = Math.min(100, Math.max(0, pct));
        this.lastPct = Math.max(this.lastPct, v);
        if (this.barFill) this.barFill.style.width = this.lastPct + "%";
        if (this.percent) this.percent.textContent = Math.floor(this.lastPct) + "%";
    },

    setStage(text) {
        if (text && this.stage) this.stage.textContent = text;
    },

    rotateTip() {
        if (!this.tip) return;
        this.tip.classList.remove("bab-tip-in");
        void this.tip.offsetWidth;
        this.tip.textContent = this.tips[this.tipIndex % this.tips.length];
        this.tipIndex += 1;
        this.tip.classList.add("bab-tip-in");
    },

    hide() {
        if (!this.overlay) return;
        clearInterval(this.tipTimer);
        clearInterval(this.syncTimer);
        this.overlay.classList.add("bab-loader-out");
        setTimeout(() => {
            this.overlay.style.display = "none";
        }, 650);
    }
};

function show_infobox() {
    infobox.style.display = "block";
    const w = infobox.offsetWidth;
    const h = infobox.offsetHeight;
    infobox.style.left = ((window.innerWidth - w) / 2) + "px";
    infobox.style.top = ((window.innerHeight - h) / 2) + "px";
}

</script>

    <title>{{cookiecutter.title}}</title>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes"/>
    <link rel="icon" type="image/png" href="favicon.png" sizes="16x16">

    <style>
        :root {
            --bab-cyan: #5ee7ff;
            --bab-magenta: #ff6eb4;
            --bab-gold: #ffd56a;
            --bab-bg0: #030712;
            --bab-bg1: #0a1628;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            padding: 0;
            font-family: "Segoe UI", "Hiragino Sans", "Yu Gothic UI", sans-serif;
            background: radial-gradient(ellipse at 50% 20%, #142238 0%, var(--bab-bg0) 55%, #000 100%);
            color: #e8f4ff;
            overflow: hidden;
        }

        #bab-loader {
            position: fixed;
            inset: 0;
            z-index: 999990;
            display: flex;
            align-items: center;
            justify-content: center;
            background:
                radial-gradient(circle at 20% 80%, rgba(94, 231, 255, 0.08) 0%, transparent 45%),
                radial-gradient(circle at 80% 20%, rgba(255, 110, 180, 0.07) 0%, transparent 40%),
                linear-gradient(160deg, var(--bab-bg1) 0%, var(--bab-bg0) 100%);
            transition: opacity 0.55s ease, transform 0.55s ease;
        }

        #bab-loader.bab-loader-out {
            opacity: 0;
            transform: scale(1.03);
            pointer-events: none;
        }

        .bab-stars {
            position: absolute;
            inset: 0;
            overflow: hidden;
            pointer-events: none;
        }

        .bab-stars span {
            position: absolute;
            width: 2px;
            height: 2px;
            background: #fff;
            border-radius: 50%;
            opacity: 0.35;
            animation: bab-twinkle 2.4s ease-in-out infinite;
        }

        @keyframes bab-twinkle {
            0%, 100% { opacity: 0.15; transform: scale(1); }
            50% { opacity: 0.9; transform: scale(1.4); }
        }

        .bab-shooter {
            position: absolute;
            width: 12px;
            height: 20px;
            background: linear-gradient(180deg, var(--bab-cyan), #1a6bff);
            border-radius: 40% 40% 20% 20%;
            box-shadow: 0 0 12px rgba(94, 231, 255, 0.7);
            animation: bab-fly 6s linear infinite;
            opacity: 0.55;
        }

        .bab-shooter::after {
            content: "";
            position: absolute;
            bottom: -8px;
            left: 50%;
            transform: translateX(-50%);
            width: 4px;
            height: 10px;
            background: rgba(255, 213, 106, 0.8);
            border-radius: 2px;
            animation: bab-thrust 0.15s alternate infinite;
        }

        @keyframes bab-fly {
            0% { transform: translate(-10vw, 110vh) rotate(-12deg); }
            100% { transform: translate(110vw, -20vh) rotate(-12deg); }
        }

        @keyframes bab-thrust {
            from { height: 8px; opacity: 0.5; }
            to { height: 14px; opacity: 1; }
        }

        .bab-panel {
            position: relative;
            width: min(92vw, 520px);
            padding: 2rem 1.75rem 1.6rem;
            border: 1px solid rgba(94, 231, 255, 0.35);
            border-radius: 16px;
            background: rgba(6, 14, 28, 0.82);
            box-shadow:
                0 0 40px rgba(94, 231, 255, 0.12),
                inset 0 0 60px rgba(0, 0, 0, 0.35);
            backdrop-filter: blur(8px);
            text-align: center;
        }

        .bab-logo {
            width: 72px;
            height: 72px;
            margin: 0 auto 0.75rem;
            animation: bab-pulse 2s ease-in-out infinite;
            filter: drop-shadow(0 0 12px rgba(94, 231, 255, 0.5));
        }

        @keyframes bab-pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.06); }
        }

        .bab-title {
            margin: 0 0 0.25rem;
            font-size: clamp(1.1rem, 4vw, 1.45rem);
            letter-spacing: 0.06em;
            color: var(--bab-cyan);
            text-shadow: 0 0 20px rgba(94, 231, 255, 0.35);
        }

        .bab-sub {
            margin: 0 0 1.25rem;
            font-size: 0.78rem;
            color: rgba(200, 220, 255, 0.65);
            letter-spacing: 0.12em;
        }

        #bab-stage {
            min-height: 1.4em;
            margin-bottom: 0.85rem;
            font-size: 0.95rem;
            color: #c8e6ff;
        }

        .bab-bar-track {
            position: relative;
            height: 14px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.08);
            overflow: hidden;
            border: 1px solid rgba(94, 231, 255, 0.25);
        }

        #bab-bar-fill {
            height: 100%;
            width: 0%;
            border-radius: 999px;
            background: linear-gradient(90deg, #1a6bff, var(--bab-cyan), var(--bab-gold));
            background-size: 200% 100%;
            animation: bab-bar-shine 1.8s linear infinite;
            transition: width 0.25s ease-out;
            box-shadow: 0 0 16px rgba(94, 231, 255, 0.55);
        }

        @keyframes bab-bar-shine {
            0% { background-position: 100% 0; }
            100% { background-position: -100% 0; }
        }

        #bab-percent {
            margin-top: 0.55rem;
            font-size: 1.65rem;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
            color: var(--bab-gold);
            text-shadow: 0 0 12px rgba(255, 213, 106, 0.4);
        }

        #bab-tip {
            margin-top: 1.1rem;
            min-height: 2.6em;
            font-size: 0.82rem;
            line-height: 1.55;
            color: rgba(180, 210, 255, 0.75);
            opacity: 0;
            transform: translateY(6px);
        }

        #bab-tip.bab-tip-in {
            animation: bab-tip-in 0.45s ease forwards;
        }

        @keyframes bab-tip-in {
            to { opacity: 1; transform: translateY(0); }
        }

        .bab-dots {
            margin-top: 0.75rem;
            letter-spacing: 0.35em;
            color: var(--bab-magenta);
            animation: bab-dots 1.2s steps(4, end) infinite;
        }

        @keyframes bab-dots {
            0% { opacity: 0.2; }
            50% { opacity: 1; }
            100% { opacity: 0.2; }
        }

        #infobox {
            position: fixed;
            z-index: 999999;
            display: none;
            padding: 16px 28px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1.05rem;
            text-align: center;
            cursor: pointer;
        }

        #infobox.bab-start-prompt {
            background: linear-gradient(135deg, rgba(26, 107, 255, 0.92), rgba(94, 231, 255, 0.85));
            color: #041018;
            border: 2px solid rgba(255, 255, 255, 0.45);
            box-shadow: 0 0 30px rgba(94, 231, 255, 0.45);
            animation: bab-start-pulse 1.6s ease-in-out infinite;
        }

        @keyframes bab-start-pulse {
            0%, 100% { transform: scale(1); box-shadow: 0 0 20px rgba(94, 231, 255, 0.35); }
            50% { transform: scale(1.03); box-shadow: 0 0 36px rgba(94, 231, 255, 0.6); }
        }

        #transfer { display: none !important; }

        #status, #progress { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }

        canvas.emscripten {
            border: 0 none;
            background-color: transparent;
            width: 100%;
            height: 100%;
            z-index: 5;
            padding: 0;
            margin: 0 auto;
            position: absolute;
            top: 0; bottom: 0; left: 0; right: 0;
        }

        div.emscripten { text-align: center; }
        div.emscripten_border { border: 1px solid black; }

        .topright { position: absolute; top: 0; right: 0; }
        .bottomright { position: absolute; top: 40%; right: 0; }
        .center { display: flex; align-items: center; justify-content: center; }
        .trinfo { position: relative; right: 0; border: 1px solid black; }
        .framed { position: relative; top: 150px; right: 10px; border: 1px solid black; }
    </style>

</head>

