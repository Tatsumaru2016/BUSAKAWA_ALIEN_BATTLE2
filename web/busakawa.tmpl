import sys
import asyncio
import platform
import json
from pathlib import Path

async def bab_set_stage(msg, pct=None):
    try:
        w = platform.window
        el = w.document.getElementById("bab-stage")
        if el:
            el.innerText = msg
        if pct is not None:
            w.eval(f"window.BABLoader && BABLoader.setPercent({float(pct)})")
    except Exception:
        pass

async def bab_hide_loader():
    try:
        platform.window.eval("window.BABLoader && BABLoader.hide()")
    except Exception:
        pass

async def custom_site():
    import embed
    platform.window.transfer.hidden = True
    platform.window.canvas.style.visibility = "visible"

    bundle = "{{cookiecutter.archive}}"
    appdir = Path(f"/data/data/{bundle}")
    appdir.mkdir()

    await bab_set_stage("アーカイブを展開しています…", 82)

    if platform.window.location.host.find('.itch.zone')>0:
        import zipfile
        async with platform.fopen("{{cookiecutter.archive}}.apk", "rb") as archive:
            with zipfile.ZipFile(archive) as zip_ref:
                zip_ref.extractall(appdir.as_posix())
    else:
        import tarfile
        async with platform.fopen("{{cookiecutter.archive}}.tar.gz", "rb") as archive:
            tar = tarfile.open(fileobj=archive, mode="r:gz")
            tar.extractall(path=appdir.as_posix(), filter='tar')
            tar.close()

    await bab_set_stage("Python ランタイムを起動しています…", 88)
    platform.run_main(PyConfig, loaderhome= appdir / "assets", loadermain=None)

    tick = 0
    while embed.counter() < 0:
        tick += 1
        pct = 88 + min(7.0, tick * 0.12)
        await bab_set_stage("ゲームデータを読み込んでいます…", pct)
        await asyncio.sleep(.1)

    main = appdir / "assets" / "main.py"

    if not platform.window.MM.UME:
        __import__(__name__).__file__ = main
        msg = "準備完了！画面をタップ / クリックで開始"
        platform.window.infobox.innerText = msg
        platform.window.infobox.className = "bab-start-prompt"
        platform.window.infobox.style.display = "block"
        await bab_hide_loader()
        while not platform.window.MM.UME:
            await asyncio.sleep(.1)

    await TopLevel_async_handler.start_toplevel(platform.shell, console=window.python.config.debug)
    __import__(__name__).__file__ = main

    def ui_callback(pkg):
        platform.window.infobox.innerText = f"モジュール読込中: {pkg}"
        try:
            el = platform.window.document.getElementById("bab-stage")
            if el:
                el.innerText = f"モジュール読込中: {pkg}"
        except Exception:
            pass

    await bab_set_stage("ゲームを起動しています…", 96)
    await shell.source(main, callback=ui_callback)

    await bab_hide_loader()
    platform.window.infobox.style.display = "none"
    platform.window.config.gui_divider = 1
    platform.window.window_resize()
    shell.interactive()

asyncio.run( custom_site() )

